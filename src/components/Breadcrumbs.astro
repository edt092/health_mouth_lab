---
// Heurístico 1 (visibilidad del estado) + heurístico 6 (reconocer, no recordar).
// Coincide 1:1 con el BreadcrumbList JSON-LD inyectado por cada página (utils/schema.ts).
interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
---
<!--
  overflow-x-auto + flex-nowrap en vez de flex-wrap: en páginas de nivel 4
  (Home / categoría / subcategoría / artículo) el breadcrumb se partía en dos
  líneas en móvil (hallazgo #21). Ahora es una tira de una sola línea con
  scroll horizontal si no cabe, sin perder ningún nivel.
-->
<nav aria-label="Breadcrumb" class="overflow-x-auto px-6 py-4 text-sm text-brand-text/70">
  <ol class="flex flex-nowrap items-center gap-1 whitespace-nowrap">
    {items.map((item, i) => (
      <li class="flex shrink-0 items-center gap-1">
        {i > 0 && <span aria-hidden="true">/</span>}
        {i < items.length - 1 ? (
          <a href={item.url} class="hover:text-brand-primary">{item.name}</a>
        ) : (
          <span aria-current="page" class="text-brand-text">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
