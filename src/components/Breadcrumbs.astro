---
// Heurístico 1 (visibilidad del estado) + heurístico 6 (reconocer, no recordar).
// Coincide 1:1 con el BreadcrumbList JSON-LD inyectado por cada página (utils/schema.ts).
interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
---
<nav aria-label="Breadcrumb" class="px-6 py-4 text-sm text-brand-text/70">
  <ol class="flex flex-wrap gap-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true">/</span>}
        {i < items.length - 1 ? (
          <a href={item.url} class="hover:text-brand-primary">{item.name}</a>
        ) : (
          <span aria-current="page" class="text-brand-text">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
