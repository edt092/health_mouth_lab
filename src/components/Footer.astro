---
import { CATEGORY_META, CATEGORY_SLUGS } from '../data/categories';
---
<footer class="mt-16 border-t border-brand-text/10 px-6 py-10 text-sm">
  <nav aria-label="Footer navigation" class="grid grid-cols-2 gap-3 md:grid-cols-4">
    {CATEGORY_SLUGS.map((slug) => <a href={`/${slug}/`}>{CATEGORY_META[slug].label}</a>)}
    <a href="/dentabiome/">Dentabiome</a>
    <a href="/dentabiome/reviews/">Reviews</a>
  </nav>
  <p class="mt-8 text-brand-text/60">
    &copy; {new Date().getFullYear()} Healthy Mouth Lab. Content is for informational purposes and reviewed by
    licensed dental professionals; it does not replace professional dental advice.
  </p>
</footer>
