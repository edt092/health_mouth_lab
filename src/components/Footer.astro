---
import { CATEGORY_META, CATEGORY_SLUGS } from '../data/categories';
import AffiliateDisclosure from './AffiliateDisclosure.astro';
---
<footer class="mt-16 border-t border-brand-text/10 px-6 py-10 text-sm">
  <nav aria-label="Footer navigation" class="grid grid-cols-2 gap-3 md:grid-cols-4">
    {CATEGORY_SLUGS.map((slug) => <a href={`/${slug}/`}>{CATEGORY_META[slug].label}</a>)}
    <a href="/dentabiome/">Dentabiome</a>
    <a href="/dentabiome/reviews/">Reviews</a>
  </nav>
  <nav aria-label="Legal navigation" class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-brand-text/70">
    <a href="/about/">About</a>
    <a href="/contact/">Contact</a>
    <a href="/privacy-policy/">Privacy Policy</a>
    <a href="/terms/">Terms of Use</a>
  </nav>
  <p class="mt-8 text-brand-text/60">
    &copy; {new Date().getFullYear()} Healthy Mouth Lab. Content is for informational purposes only and is
    fact-checked against cited research by our editorial team; it does not replace professional dental advice.
  </p>
  <div class="mt-3">
    <AffiliateDisclosure />
  </div>
</footer>
