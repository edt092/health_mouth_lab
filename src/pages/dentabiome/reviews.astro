---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { buildBreadcrumbSchema, buildReviewSchema } from '../../utils/schema';
import { AFFILIATE_URL, AFFILIATE_LINK_ATTRS } from '../../data/affiliate';

const entry = await getEntry('product', 'dentabiome');
if (!entry) throw new Error('Missing product entry: dentabiome');
const { editorialReview } = entry.data;

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Dentabiome', url: '/dentabiome/' },
  { name: 'Reviews', url: '/dentabiome/reviews/' },
];
---
<Layout
  title="Dentabiome Review | Healthy Mouth Lab"
  description="Our editorial review of Dentabiome — scored on category research backing, guarantee terms, ingredient transparency and routine fit."
  canonicalPath="/dentabiome/reviews/"
  pageType="product"
  schema={[
    buildBreadcrumbSchema(breadcrumbItems),
    buildReviewSchema({
      itemName: entry.data.name,
      reviewBody: editorialReview.summary,
      ratingValue: editorialReview.score,
      bestRating: editorialReview.scale,
      author: editorialReview.reviewer,
      datePublished: editorialReview.datePublished,
      url: '/dentabiome/reviews/',
    }),
  ]}
>
  <Header slot="header" />
  <Breadcrumbs items={breadcrumbItems} />

  <div class="px-6 py-8">
    <h1 class="text-3xl font-bold">Our Dentabiome Review</h1>

    <p class="mt-2 text-2xl font-semibold text-brand-primary">
      {editorialReview.score}/{editorialReview.scale}
    </p>

    <p class="mt-3 text-sm text-brand-text/60">
      Reviewed by {editorialReview.reviewer} · Last updated{' '}
      {editorialReview.datePublished.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </p>

    <p class="mt-4 max-w-measure text-brand-text/80">{editorialReview.summary}</p>

    <div class="mt-3 max-w-measure">
      <AffiliateDisclosure />
      <p class="mt-1 text-xs text-brand-text/60">
        This score is our own editorial assessment based on publicly available product information — it is not
        a survey of verified customer reviews.
      </p>
    </div>

    <section class="mt-8 space-y-4" aria-label="Review criteria breakdown">
      <h2 class="text-xl font-semibold">How we scored it</h2>
      {editorialReview.criteria.map((c) => (
        <div class="border-b border-brand-text/10 pb-3">
          <div class="flex items-baseline justify-between gap-4">
            <h3 class="font-medium">{c.label}</h3>
            <span class="whitespace-nowrap text-sm font-semibold text-brand-primary">
              {c.score}/{editorialReview.scale}
            </span>
          </div>
          <p class="mt-1 text-sm text-brand-text/70">{c.notes}</p>
        </div>
      ))}
    </section>

    <a
      href={AFFILIATE_URL}
      {...AFFILIATE_LINK_ATTRS}
      class="mt-8 inline-block rounded-md bg-brand-primary px-6 py-3 font-medium text-white hover:opacity-90"
    >
      Get Dentabiome Today →
    </a>
    <a href="/dentabiome/" class="mt-3 block text-sm font-medium text-brand-primary underline">
      ← Back to Dentabiome overview
    </a>
  </div>

  <Footer slot="footer" />
</Layout>
