---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { buildBreadcrumbSchema, buildProductSchema, buildFAQSchema } from '../../utils/schema';
import { AFFILIATE_URL, AFFILIATE_LINK_ATTRS } from '../../data/affiliate';

const entry = await getEntry('product', 'dentabiome');
if (!entry) throw new Error('Missing product entry: dentabiome');
const { Content } = await render(entry);

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Dentabiome', url: '/dentabiome/' },
];
---
<Layout
  title={`${entry.data.seo.title} | Healthy Mouth Lab`}
  description={entry.data.seo.description}
  canonicalPath="/dentabiome/"
  pageType="product"
  schema={[
    buildBreadcrumbSchema(breadcrumbItems),
    buildProductSchema({
      name: entry.data.name,
      description: entry.data.seo.description,
      price: entry.data.price,
      currency: entry.data.currency,
      availability: entry.data.availability,
      url: '/dentabiome/',
      review: {
        ratingValue: entry.data.editorialReview.score,
        bestRating: entry.data.editorialReview.scale,
        author: entry.data.editorialReview.reviewer,
        reviewBody: entry.data.editorialReview.summary,
        datePublished: entry.data.editorialReview.datePublished,
      },
    }),
    buildFAQSchema(entry.data.faqs),
  ]}
>
  <Header slot="header" />
  <Breadcrumbs items={breadcrumbItems} />

  <div class="px-6 py-8">
    <h1 class="text-3xl font-bold">{entry.data.name}</h1>
    <p class="mt-1 text-sm text-brand-text/60">
      Our Rating: {entry.data.editorialReview.score}/{entry.data.editorialReview.scale} (Editorial Review)
      · ${entry.data.price} {entry.data.currency}
    </p>

    <a
      href={AFFILIATE_URL}
      {...AFFILIATE_LINK_ATTRS}
      class="mt-4 inline-block rounded-md bg-brand-primary px-6 py-3 font-medium text-white hover:opacity-90"
    >
      Get Dentabiome Today →
    </a>
    <p class="mt-2 text-xs text-brand-text/60">30-day money-back guarantee</p>
    <div class="mt-2 max-w-measure">
      <AffiliateDisclosure />
    </div>

    <div class="prose mt-6 max-w-measure">
      <Content />
    </div>

    <nav aria-label="Learn more" class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm">
      <a href="/dentabiome/how-it-works/" class="underline">How it works</a>
      <a href="/dentabiome/reviews/" class="underline">Read our full review</a>
    </nav>

    <section aria-label="Frequently asked questions" class="mt-10 space-y-4">
      <h2 class="text-xl font-semibold">FAQ</h2>
      {entry.data.faqs.map((faq) => (
        <div>
          <h3 class="font-medium">{faq.question}</h3>
          <p class="text-brand-text/70">{faq.answer}</p>
        </div>
      ))}
    </section>

    <a
      href={AFFILIATE_URL}
      {...AFFILIATE_LINK_ATTRS}
      class="mt-10 inline-block rounded-md bg-brand-primary px-6 py-3 font-medium text-white hover:opacity-90"
    >
      Get Dentabiome Today →
    </a>
  </div>

  <Footer slot="footer" />
</Layout>
