---
// Página oportunista detectada en INFORME_ARQUITECTURA_SEO_DENTABIOME.md (Cluster 7):
// "parodontax extra fresh" es keyword de marca de un competidor con intención transaccional.
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildBreadcrumbSchema } from '../../utils/schema';
import { AFFILIATE_URL, AFFILIATE_LINK_ATTRS } from '../../data/affiliate';

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Dentabiome', url: '/dentabiome/' },
  { name: 'Dentabiome vs. Parodontax', url: '/dentabiome/vs-parodontax/' },
];
---
<Layout
  title="Dentabiome vs. Parodontax: Which Is Better for Gum Health? | Healthy Mouth Lab"
  description="A direct comparison between Dentabiome's oral probiotic approach and Parodontax toothpaste for gum health."
  canonicalPath="/dentabiome/vs-parodontax/"
  pageType="product"
  schema={buildBreadcrumbSchema(breadcrumbItems)}
>
  <Header slot="header" />
  <Breadcrumbs items={breadcrumbItems} />
  <div class="px-6 py-8">
    <h1 class="text-3xl font-bold">Dentabiome vs. Parodontax</h1>
    <p class="mt-4 max-w-measure text-brand-text/80">
      Comparison table: mechanism (probiotic rebalancing vs. antibacterial toothpaste), daily routine fit, and
      independent review evidence.
    </p>
    <a
      href={AFFILIATE_URL}
      {...AFFILIATE_LINK_ATTRS}
      class="mt-6 inline-block rounded-md bg-brand-primary px-6 py-3 font-medium text-white hover:opacity-90"
    >
      Try Dentabiome →
    </a>
    <a href="/dentabiome/" class="mt-3 block text-sm font-medium text-brand-primary underline">
      ← Back to Dentabiome overview
    </a>
  </div>
  <Footer slot="footer" />
</Layout>
