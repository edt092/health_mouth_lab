---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import { buildBreadcrumbSchema, buildOrganizationSchema, buildWebSiteSchema } from '../utils/schema';
import { CATEGORY_META, CATEGORY_SLUGS } from '../data/categories';
import { AFFILIATE_URL, AFFILIATE_LINK_ATTRS } from '../data/affiliate';
---
<Layout
  title="Healthy Mouth Lab — Understand Your Oral Microbiome"
  description="In-depth guides on gum health, bad breath, dry mouth and the oral microbiome — and the probiotic that addresses the root cause."
  canonicalPath="/"
  pageType="website"
  schema={[
    buildOrganizationSchema(),
    buildWebSiteSchema(),
    buildBreadcrumbSchema([{ name: 'Home', url: '/' }]),
  ]}
>
  <Header slot="header" />

  <section class="px-6 py-16 text-center">
    <h1 class="mx-auto max-w-3xl text-4xl font-bold leading-tight">
      Understand Your Oral Microbiome. Fix the Cause, Not the Symptom.
    </h1>
    <p class="mt-4 text-brand-text/70">Research-backed content. No jargon.</p>
    <a
      href="/oral-microbiome/"
      class="mt-6 inline-block rounded-md bg-brand-primary px-6 py-3 font-medium text-white"
    >
      Explore the Oral Microbiome
    </a>
    <p class="mt-6 text-sm text-brand-text/60">
      ✓ Research-backed &nbsp; ✓ 30-day guarantee &nbsp; ✓ 10,000+ users
    </p>
  </section>

  <section aria-label="Featured pillars" class="grid gap-4 px-6 py-8 md:grid-cols-2">
    <a href="/oral-microbiome/" class="rounded-lg border border-brand-text/10 p-6">
      <h2 class="text-lg font-semibold">Oral Microbiome</h2>
      <p class="text-sm text-brand-text/70">The pillar behind every symptom on this site.</p>
    </a>
    <a href="/gum-health/" class="rounded-lg border border-brand-text/10 p-6">
      <h2 class="text-lg font-semibold">Gum Health</h2>
      <p class="text-sm text-brand-text/70">Our highest-traffic symptom cluster.</p>
    </a>
  </section>

  <section aria-label="Browse by symptom" class="grid gap-3 px-6 py-8 md:grid-cols-3">
    {CATEGORY_SLUGS.map((slug, i) => (
      <a href={`/${slug}/`} class="overflow-hidden rounded-lg border border-brand-text/10 hover:border-brand-primary">
        <Image
          src={CATEGORY_META[slug].image}
          alt={CATEGORY_META[slug].label}
          widths={[240, 480]}
          sizes="(min-width: 768px) 33vw, 100vw"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          class="aspect-[3/2] w-full object-cover"
        />
        <p class="p-4 font-medium">{CATEGORY_META[slug].label}</p>
      </a>
    ))}
  </section>

  <section aria-label="Recommended solution" class="mx-6 my-12 rounded-lg border border-brand-text/10 bg-brand-primary/5 px-6 py-10 text-center">
    <p class="text-xs font-semibold uppercase tracking-wide text-brand-primary">Root-cause support</p>
    <h2 class="mx-auto mt-2 max-w-xl text-2xl font-bold">
      Rebalance your oral microbiome with Dentabiome
    </h2>
    <p class="mx-auto mt-2 max-w-xl text-sm text-brand-text/70">
      The dentist-formulated oral probiotic behind the fixes in this guide — for gum health, fresh breath and dry mouth.
    </p>
    <a
      href={AFFILIATE_URL}
      {...AFFILIATE_LINK_ATTRS}
      class="mt-5 inline-block rounded-md bg-brand-primary px-6 py-3 font-medium text-white hover:opacity-90"
    >
      Get Dentabiome Today →
    </a>
    <div class="mx-auto mt-4 max-w-xl">
      <AffiliateDisclosure />
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
