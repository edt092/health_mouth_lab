---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { buildBreadcrumbSchema } from '../../utils/schema';

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Terms of Use', url: '/terms/' },
];

const LAST_UPDATED = 'July 14, 2026';
---
<Layout
  title="Terms of Use | Healthy Mouth Lab"
  description="The terms governing your use of Healthy Mouth Lab, including our medical disclaimer and affiliate disclosure."
  canonicalPath="/terms/"
  pageType="website"
  schema={buildBreadcrumbSchema(breadcrumbItems)}
>
  <Header slot="header" />
  <Breadcrumbs items={breadcrumbItems} />

  <div class="mx-auto max-w-measure px-6 py-8">
    <h1 class="text-3xl font-bold">Terms of Use</h1>
    <p class="mt-2 text-sm text-brand-text/60">Last updated: {LAST_UPDATED}</p>

    <div class="prose mt-6 max-w-none">
      <p>
        By using healthymouthlab.online ("the site"), you agree to these terms. If you don't agree, please don't
        use the site.
      </p>

      <h2>Not medical advice</h2>
      <p>
        Content on this site is for general educational purposes only. It is written and reviewed by the Healthy
        Mouth Lab editorial team and does not replace professional dental or medical advice, diagnosis, or
        treatment. Always consult a licensed dentist or physician with questions about a specific condition
        before making treatment decisions, and never disregard professional advice because of something you read
        here.
      </p>

      <h2>Affiliate disclosure</h2>
      <AffiliateDisclosure />
      <p>
        Where we recommend a product, that recommendation may be compensated. See our
        <a href="/dentabiome/reviews/">editorial review methodology</a> for how we score what we cover.
      </p>

      <h2>Third-party products and guarantees</h2>
      <p>
        Product availability, pricing, and guarantee terms (such as any money-back guarantee mentioned on this
        site) are set by the product vendor and/or ClickBank, not by Healthy Mouth Lab. We describe these terms
        as accurately as we can at the time of publication, but the vendor's own terms govern any purchase — we
        recommend confirming current terms on the vendor's page before buying.
      </p>

      <h2>No professional relationship</h2>
      <p>
        Using this site, submitting our contact form, or reading our content does not create a
        dentist-patient, medical, or other professional relationship between you and Healthy Mouth Lab.
      </p>

      <h2>Content ownership</h2>
      <p>
        Unless otherwise noted, the text, graphics and layout on this site belong to Healthy Mouth Lab. You're
        welcome to link to our pages; please don't republish substantial portions of our content elsewhere
        without permission.
      </p>

      <h2>No warranty; limitation of liability</h2>
      <p>
        This site and its content are provided "as is," without warranties of any kind, express or implied. To
        the fullest extent permitted by law, Healthy Mouth Lab is not liable for any damages arising from your
        use of the site or reliance on its content, including outcomes related to any product mentioned here.
      </p>

      <h2>External links</h2>
      <p>
        This site links to third-party sites, including research sources and our affiliate partner. We don't
        control those sites and aren't responsible for their content, accuracy, or privacy practices.
      </p>

      <h2>Changes to these terms</h2>
      <p>
        We may update these terms as the site evolves. The "Last updated" date above reflects the most recent
        revision. Continued use of the site after a change means you accept the updated terms.
      </p>

      <h2>Contact us</h2>
      <p>
        Questions about these terms can be sent through our <a href="/contact/">contact form</a>.
      </p>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>
