---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildBreadcrumbSchema } from '../../utils/schema';

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Privacy Policy', url: '/privacy-policy/' },
];

const LAST_UPDATED = 'July 14, 2026';
---
<Layout
  title="Privacy Policy | Healthy Mouth Lab"
  description="What information Healthy Mouth Lab collects, how contact form submissions are handled, and how affiliate links work."
  canonicalPath="/privacy-policy/"
  pageType="website"
  schema={buildBreadcrumbSchema(breadcrumbItems)}
>
  <Header slot="header" />
  <Breadcrumbs items={breadcrumbItems} />

  <div class="mx-auto max-w-measure px-6 py-8">
    <h1 class="text-3xl font-bold">Privacy Policy</h1>
    <p class="mt-2 text-sm text-brand-text/60">Last updated: {LAST_UPDATED}</p>

    <div class="prose mt-6 max-w-none">
      <p>
        Healthy Mouth Lab ("we", "us") publishes this policy to explain what happens with information related to
        your visit to healthymouthlab.online.
      </p>

      <h2>Information we collect</h2>
      <p>
        This site does not require an account, does not use cookies, and does not run analytics or advertising
        tracking scripts of its own. We do not collect personal information simply by your browsing the site.
      </p>

      <h2>Contact form submissions</h2>
      <p>
        If you use our <a href="/contact/">contact form</a>, the name, email address and message you submit are
        processed by Netlify, our website hosting provider, and delivered to us so we can respond to you. We use
        this information only to reply to your message and do not sell or share it with third parties for
        marketing purposes.
      </p>

      <h2>Hosting and server logs</h2>
      <p>
        Like most websites, basic technical information (such as IP address, browser type and request timestamps)
        may be logged automatically by our hosting provider, Netlify, for security and reliability purposes. This
        is standard infrastructure logging, not something we configure or use for tracking individuals. See
        <a href="https://www.netlify.com/privacy/" target="_blank" rel="noopener">Netlify's own privacy policy</a>
        for details on how they handle this data.
      </p>

      <h2>Affiliate links</h2>
      <p>
        This site contains affiliate links to Dentabiome, sold via ClickBank. If you click one of these links and
        make a purchase, we may earn a commission at no extra cost to you. We do not receive your payment details
        or any personal information you provide during checkout — that transaction is handled entirely by the
        vendor and ClickBank, under their own privacy policies.
      </p>

      <h2>Children's privacy</h2>
      <p>This site is not directed at children under 13, and we do not knowingly collect information from them.</p>

      <h2>Changes to this policy</h2>
      <p>
        We may update this policy from time to time as the site changes (for example, if we add analytics or a
        new contact method). The "Last updated" date above will reflect the most recent revision.
      </p>

      <h2>Contact us</h2>
      <p>
        Questions about this policy can be sent through our <a href="/contact/">contact form</a>.
      </p>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>
