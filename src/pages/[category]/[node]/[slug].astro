---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import BridgeCard from '../../../components/BridgeCard.astro';
import { buildBreadcrumbSchema, buildArticleSchema, buildFAQSchema } from '../../../utils/schema';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((entry) => {
    const [category, node, slug] = entry.id.split('/');
    return { params: { category, node, slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { category, node, slug } = Astro.params as { category: string; node: string; slug: string };
const { Content } = await render(entry);

const bridges = await getCollection('bridges');
const bridge = bridges.find((b) => b.data.category === category);

const canonicalPath = `/${category}/${node}/${slug}/`;
const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: category.replace(/-/g, ' '), url: `/${category}/` },
  { name: node.replace(/-/g, ' '), url: `/${category}/${node}/` },
  { name: entry.data.title, url: canonicalPath },
];
---
<Layout
  title={`${entry.data.seo.title} | Healthy Mouth Lab`}
  description={entry.data.seo.description}
  canonicalPath={canonicalPath}
  pageType="article"
  schema={[
    buildBreadcrumbSchema(breadcrumbItems),
    buildArticleSchema({
      title: entry.data.title,
      description: entry.data.seo.description,
      author: entry.data.author,
      datePublished: entry.data.publishDate,
      dateModified: entry.data.updatedDate ?? entry.data.publishDate,
      url: canonicalPath,
    }),
    ...(entry.data.faqs && entry.data.faqs.length > 0 ? [buildFAQSchema(entry.data.faqs)] : []),
  ]}
>
  <Header slot="header" />
  <Breadcrumbs items={breadcrumbItems} />

  <!--
    El texto sigue envuelto a `max-w-measure` (70ch, decisión tipográfica
    intencional — UX §3), pero el marco exterior del artículo se ensanchó de
    70ch a max-w-3xl: en monitores anchos, una columna de 470px dentro de un
    viewport de 1920px se percibía como diseño sin terminar (hallazgo visual
    #16). Ensanchar el marco reduce ese vacío sin tocar el largo de línea real.
  -->
  <article class="mx-auto max-w-3xl px-6 py-8">
    <h1 class="text-h1">{entry.data.title}</h1>
    <p class="mt-2 text-sm text-brand-text/60">
      By {entry.data.author} · Fact-checked against cited sources · {entry.data.readingTime} min read
    </p>
    <div class="prose mt-6 max-w-measure">
      <Content />
    </div>

    {entry.data.faqs && entry.data.faqs.length > 0 && (
      <section aria-label="Frequently asked questions" class="mt-12 max-w-measure border-t border-brand-text/10 pt-8">
        <h2 class="text-h2">Frequently Asked Questions</h2>
        {entry.data.faqs.map((faq) => (
          <div class="mt-6">
            <h3 class="text-h3">{faq.question}</h3>
            <p class="mt-2 text-brand-text/80">{faq.answer}</p>
          </div>
        ))}
      </section>
    )}
  </article>

  <div class="mx-auto max-w-3xl px-6">
    {bridge && <BridgeCard entry={bridge} />}
  </div>

  <Footer slot="footer" />
</Layout>
