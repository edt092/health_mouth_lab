---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import AffiliateDisclosure from '../../../components/AffiliateDisclosure.astro';
import { buildBreadcrumbSchema } from '../../../utils/schema';
import { AFFILIATE_URL, AFFILIATE_LINK_ATTRS } from '../../../data/affiliate';

const STATUS_LABEL = { meets: 'Meets', partial: 'Partially meets', unverified: 'Unverified' } as const;
const STATUS_CLASS = {
  meets: 'bg-green-100 text-green-800',
  partial: 'bg-amber-100 text-amber-800',
  unverified: 'bg-brand-text/10 text-brand-text/70',
} as const;

// Un solo archivo resuelve las dos "hojas" de nivel 2 de la silo: la subcategoría
// (listado de artículos) y la página puente (comercial). Se distinguen por `type`
// en props, no por convención de nombre de archivo — evita colisión de rutas
// entre "carpeta con index" y "archivo dinámico" en el mismo nivel.
type Props =
  | { type: 'subcategory' }
  | { type: 'bridge'; entry: CollectionEntry<'bridges'> };

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const bridges = await getCollection('bridges');

  const subcategoryPaths = [...new Set(articles.map((a) => `${a.data.category}/${a.data.subcategory}`))].map(
    (key) => {
      const [category, node] = key.split('/');
      return { params: { category, node }, props: { type: 'subcategory' as const } };
    },
  );

  const bridgePaths = bridges.map((b) => ({
    params: { category: b.data.category, node: b.id },
    props: { type: 'bridge' as const, entry: b },
  }));

  return [...subcategoryPaths, ...bridgePaths];
}

const { category, node } = Astro.params as { category: string; node: string };
const props = Astro.props as Props;

let title: string;
let description: string;
let articlesInNode: CollectionEntry<'articles'>[] = [];

if (props.type === 'subcategory') {
  articlesInNode = await getCollection(
    'articles',
    (a) => a.data.category === category && a.data.subcategory === node,
  );
  title = node.replace(/-/g, ' ');
  description = `Everything about ${title} — causes, symptoms and what actually helps.`;
} else {
  title = props.entry.data.title;
  description = props.entry.data.seo.description;
}

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: category.replace(/-/g, ' '), url: `/${category}/` },
  { name: title, url: `/${category}/${node}/` },
];
---
<Layout
  title={`${title} | Healthy Mouth Lab`}
  description={description}
  canonicalPath={`/${category}/${node}/`}
  pageType={props.type === 'bridge' ? 'product' : 'category'}
  schema={buildBreadcrumbSchema(breadcrumbItems)}
>
  <Header slot="header" />
  <Breadcrumbs items={breadcrumbItems} />

  <div class="px-6 py-8">
    <h1 class="text-3xl font-bold capitalize">{title}</h1>
    <p class="mt-2 text-brand-text/70">{description}</p>

    {props.type === 'subcategory' ? (
      <section aria-label="Articles" class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {articlesInNode.map((a, i) => (
          <a href={`/${category}/${node}/${a.id.split('/').pop()}/`} class="overflow-hidden rounded-lg border border-brand-text/10 hover:border-brand-primary">
            <Image
              src={a.data.image}
              alt={a.data.title}
              widths={[300, 600]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : 'auto'}
              class="aspect-[3/2] w-full object-cover"
            />
            <p class="p-4 text-sm font-medium">{a.data.title}</p>
          </a>
        ))}
      </section>
    ) : (
      <section aria-label="Comparison" class="mt-8 space-y-4">
        {props.entry.data.comparisonCriteria.map((c) => (
          <div class="border-b border-brand-text/10 pb-4">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <h3 class="font-medium">{c.label}</h3>
              <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${STATUS_CLASS[c.dentabiomeStatus]}`}>
                Dentabiome: {STATUS_LABEL[c.dentabiomeStatus]}
              </span>
            </div>
            <p class="mt-1 text-sm text-brand-text/70">{c.why}</p>
            <p class="mt-1 text-sm text-brand-text/60">{c.dentabiomeNote}</p>
          </div>
        ))}

        <p class="max-w-measure font-medium text-brand-text/90">{props.entry.data.verdict}</p>

        <AffiliateDisclosure />

        <a
          href={AFFILIATE_URL}
          {...AFFILIATE_LINK_ATTRS}
          class="mt-2 inline-block rounded-md bg-brand-primary px-6 py-3 font-medium text-white hover:opacity-90"
        >
          Get Dentabiome →
        </a>
        <a href="/dentabiome/" class="mt-3 block text-sm font-medium text-brand-primary underline">
          Learn more about Dentabiome
        </a>
      </section>
    )}
  </div>

  <Footer slot="footer" />
</Layout>
