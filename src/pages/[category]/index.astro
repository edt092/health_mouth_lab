---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BridgeCard from '../../components/BridgeCard.astro';
import { buildBreadcrumbSchema, buildItemListSchema } from '../../utils/schema';
import { CATEGORY_META, CATEGORY_SLUGS, type CategorySlug } from '../../data/categories';

export function getStaticPaths() {
  return CATEGORY_SLUGS.map((category) => ({ params: { category } }));
}

const { category } = Astro.params as { category: CategorySlug };
const meta = CATEGORY_META[category];

const allArticles = await getCollection('articles', (entry) => entry.data.category === category);
const bridges = await getCollection('bridges');
const bridge = bridges.find((b) => b.data.category === category);

const subcategories = [...new Set(allArticles.map((a) => a.data.subcategory))];

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: meta.title, url: `/${category}/` },
];

const articleLinks = allArticles.map((a) => ({
  name: a.data.title,
  url: `/${category}/${a.data.subcategory}/${a.id.split('/').pop()}/`,
}));
---
<Layout
  title={`${meta.title} | Healthy Mouth Lab`}
  description={meta.description}
  canonicalPath={`/${category}/`}
  pageType="category"
  schema={[buildBreadcrumbSchema(breadcrumbItems), buildItemListSchema(articleLinks)]}
>
  <Header slot="header" />
  <Breadcrumbs items={breadcrumbItems} />

  <div class="px-6 py-8">
    <h1 class="text-3xl font-bold">{meta.title}</h1>
    <p class="mt-2 text-brand-text/70">{meta.description}</p>

    <div class="prose mt-6 max-w-measure">
      <p class="font-medium">{meta.quickAnswer}</p>
      <p>{meta.overview}</p>
    </div>

    <section aria-label="When to see a dentist" class="mt-6 max-w-measure rounded-lg border border-brand-text/10 bg-brand-primary/5 p-5">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-primary">See a dentist if</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-brand-text/80">
        {meta.seeADentistIf.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section aria-label="Subcategories" class="mt-8 grid gap-3 md:grid-cols-2">
      {subcategories.map((sub) => (
        <a href={`/${category}/${sub}/`} class="rounded-lg border border-brand-text/10 p-4 capitalize hover:border-brand-primary">
          {sub.replace(/-/g, ' ')}
        </a>
      ))}
    </section>

    {bridge && <BridgeCard entry={bridge} />}

    <section aria-label="Articles" class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {allArticles.map((a) => (
        <a href={`/${category}/${a.data.subcategory}/${a.id.split('/').pop()}/`} class="overflow-hidden rounded-lg border border-brand-text/10 hover:border-brand-primary">
          <Image
            src={a.data.image}
            alt={a.data.title}
            widths={[300, 600]}
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            loading="lazy"
            class="aspect-[3/2] w-full object-cover"
          />
          <p class="p-4 text-sm font-medium">{a.data.title}</p>
        </a>
      ))}
    </section>
  </div>

  <Footer slot="footer" />
</Layout>
